extend layouts/default

block body
  - const postTags = String(tags || '').split(',').map((x) => x.trim()).filter(Boolean)

  if date && title
    header.blog-post-header
      nav.blog-breadcrumb(aria-label='Breadcrumb')
        ol.reset.notype
          li.inline-block
            a(href='/') Home
          li.inline-block.blog-breadcrumb-sep /
          li.inline-block
            a(href='/blog/') Blog
          li.inline-block.blog-breadcrumb-sep /
          li.inline-block
            span.blog-breadcrumb-current= title

      h1.blog-post-title= title
      .blog-post-meta
        if author_url && author
          a.blog-post-author(href=author_url rel='noopener noreferrer' target='_blank')= author
        else if author
          span.blog-post-author= author

        if author_email
          span.blog-post-sep ·
          a.blog-post-email(href=`mailto:${author_email}`)= author_email

        if date
          span.blog-post-sep ·
          time.blog-post-date(datetime=date)= date

      if postTags.length
        ul.blog-post-tags.notype.reset.notranslate
          each tagName in postTags
            li.inline-block
              span.blog-post-tag.notranslate= `#${tagName}`

  .auto-format!= yield

block scripts
  script.
    (() => {
      const entries = [...document.querySelectorAll(".blog-index-entry")];
      if (!entries.length) return;

      const readHashTag = () => {
        const raw = decodeURIComponent((location.hash || "").replace(/^#/, "")).trim().toLowerCase();
        if (!raw) return "";
        if (raw.startsWith("tag:")) return raw.slice(4).trim();
        return raw;
      };

      const applyFilter = () => {
        const tag = readHashTag();
        for (const entry of entries) {
          const tags = (entry.dataset.tags || "")
            .split(",")
            .map((part) => part.trim().toLowerCase())
            .filter(Boolean);
          const matches = !tag || tags.includes(tag);
          entry.classList.toggle("is-dimmed", !matches);
          entry.setAttribute("aria-hidden", String(Boolean(tag) && !matches));
        }

        for (const link of document.querySelectorAll(".blog-index-tag-link")) {
          const href = link.getAttribute("href") || "";
          const hashIndex = href.indexOf("#");
          if (hashIndex < 0) {
            link.classList.remove("is-active");
            continue;
          }
          const linkTag = decodeURIComponent(href.slice(hashIndex + 1)).replace(/^tag:/i, "").trim().toLowerCase();
          link.classList.toggle("is-active", Boolean(tag) && linkTag === tag);
        }
      };

      document.addEventListener("click", (event) => {
        const link = event.target.closest(".blog-index-tag-link");
        if (!link) return;

        const href = link.getAttribute("href") || "";
        const hashIndex = href.indexOf("#");
        if (hashIndex < 0) return;
        const nextTag = decodeURIComponent(href.slice(hashIndex + 1)).replace(/^tag:/i, "").trim().toLowerCase();
        const currentTag = readHashTag();

        if (nextTag && nextTag === currentTag) {
          event.preventDefault();
          history.replaceState(null, "", location.pathname + location.search);
          applyFilter();
        }
      });

      window.addEventListener("hashchange", applyFilter);
      applyFilter();
    })();
